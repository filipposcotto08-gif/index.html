function renderScadenze(){
  let list=DB.get('scadenze').sort((a,b)=>new Date(a.data)-new Date(b.data));
  const container=document.getElementById('scadenze-list');
  if(!list.length){ container.innerHTML=`<div class="empty"><div class="empty-icon">📅</div><div class="empty-title">Nessuna scadenza</div><div class="empty-sub">Clicca "Nuova Scadenza" per aggiungere</div></div>`; return; }
  const today=new Date(); today.setHours(0,0,0,0);
  container.innerHTML=list.map(s=>{
    const d=new Date(s.data); d.setHours(0,0,0,0);
    const diff=Math.round((d-today)/(1000*60*60*24));
    const urgenza = diff<0?'urgente':diff<=7?'urgente':diff<=30?'prossima':'ok';
    const label = diff<0?`Scaduta ${Math.abs(diff)}g fa`:diff===0?'Oggi':diff===1?'Domani':`${diff} giorni`;
    return `<div class="scadenza-item">
      <div class="scadenza-dot ${urgenza}"></div>
      <div class="scadenza-info">
        <div class="scadenza-titolo">${s.titolo}</div>
        <div class="scadenza-sub">${s.progetto||'—'}${s.note?` · ${s.note}`:''}</div>
      </div>
      <div style="text-align:right">
        <div class="scadenza-data">${fmtDate(s.data)}</div>
        <div style="font-size:11px;color:${urgenza==='urgente'?'#e57373':urgenza==='prossima'?'#e6a817':'#4caf7d'};margin-top:3px">${label}</div>
      </div>
      <div>${actionBtns('scadenze',s.id,s.titolo)}</div>
    </div>`;
  }).join('');
}

