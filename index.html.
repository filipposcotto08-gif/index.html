<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LDA Gestionale — Lineadiarchitettura</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Raleway:wght@200;300;400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black:    #0a0a0a;
  --dark:     #111111;
  --card:     #181818;
  --border:   rgba(255,255,255,0.07);
  --red:      #B01E28;
  --red-dark: #8a1520;
  --white:    #f4f2ef;
  --grey-1:   #888888;
  --grey-2:   #555555;
  --grey-3:   #2a2a2a;
  --green:    #2d6a4f;
  --green-bg: rgba(45,106,79,0.15);
  --yellow:   #b5830a;
  --yellow-bg:rgba(181,131,10,0.15);
  --blue:     #1a4a7a;
  --blue-bg:  rgba(26,74,122,0.15);
  --font-d:   'Cormorant', serif;
  --font-b:   'Inter', sans-serif;
  --ease:     cubic-bezier(0.22,1,0.36,1);
  --radius:   4px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;scroll-behavior:smooth;}
body{background:var(--black);color:var(--white);font-family:var(--font-b);font-weight:300;line-height:1.6;min-height:100vh;overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
ul{list-style:none;}
button{cursor:pointer;font-family:var(--font-b);}
input,select,textarea{font-family:var(--font-b);}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--dark);}
::-webkit-scrollbar-thumb{background:var(--grey-2);border-radius:2px;}

/* ── SIDEBAR ── */
.sidebar{
  position:fixed;top:0;left:0;bottom:0;width:240px;
  background:var(--dark);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  z-index:100;
  transition:transform 0.3s var(--ease);
}
.sidebar-logo{
  padding:28px 24px 24px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
}
.logo-icon{
  width:36px;height:36px;
  background:var(--red);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-d);font-size:16px;font-weight:400;
  color:var(--white);flex-shrink:0;
  letter-spacing:-0.02em;
}
.logo-text{
  font-family:var(--font-d);
  font-size:15px;font-weight:400;
  letter-spacing:0.02em;
  line-height:1.2;
}
.logo-text span{color:var(--red);font-style:italic;}
.logo-sub{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--grey-1);margin-top:2px;}

.nav-section{padding:20px 0 8px;border-bottom:1px solid var(--border);}
.nav-section-label{font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--grey-2);padding:0 24px 8px;}
.nav-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 24px;
  font-size:13px;font-weight:400;letter-spacing:0.04em;
  color:var(--grey-1);
  transition:color 0.2s,background 0.2s;
  position:relative;
  cursor:pointer;
  border:none;background:none;width:100%;text-align:left;
}
.nav-item:hover{color:var(--white);background:rgba(255,255,255,0.04);}
.nav-item.active{color:var(--white);}
.nav-item.active::before{
  content:'';position:absolute;left:0;top:4px;bottom:4px;
  width:2px;background:var(--red);
}
.nav-icon{width:16px;height:16px;opacity:0.7;flex-shrink:0;}
.nav-item.active .nav-icon{opacity:1;}
.nav-badge{
  margin-left:auto;
  background:var(--red);color:var(--white);
  font-size:10px;font-weight:600;
  padding:1px 7px;border-radius:10px;
  min-width:20px;text-align:center;
}

.sidebar-footer{
  margin-top:auto;padding:20px 24px;
  border-top:1px solid var(--border);
  font-size:11px;color:var(--grey-2);
  letter-spacing:0.06em;
}

/* ── MAIN ── */
.main{margin-left:240px;min-height:100vh;}
.topbar{
  position:sticky;top:0;z-index:50;
  background:rgba(10,10,10,0.95);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:0 36px;height:60px;
  display:flex;align-items:center;justify-content:space-between;
}
.topbar-title{font-family:var(--font-b);font-size:17px;font-weight:500;letter-spacing:0.02em;}
.topbar-title span{color:var(--red);font-style:italic;}
.topbar-actions{display:flex;gap:12px;align-items:center;}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;
  padding:9px 20px;border:none;border-radius:var(--radius);
  transition:all 0.2s;
}
.btn-primary{background:var(--red);color:var(--white);}
.btn-primary:hover{background:var(--red-dark);transform:translateY(-1px);}
.btn-ghost{background:rgba(255,255,255,0.06);color:var(--white);border:1px solid var(--border);}
.btn-ghost:hover{background:rgba(255,255,255,0.1);}
.btn-danger{background:rgba(176,30,40,0.15);color:#e57373;border:1px solid rgba(176,30,40,0.3);}
.btn-danger:hover{background:rgba(176,30,40,0.25);}
.btn-sm{padding:6px 14px;font-size:10px;}

.page{display:none;padding:32px 36px;animation:fadeIn 0.3s var(--ease);}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* ── DASHBOARD ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;}
.stat-card{
  background:var(--card);border:1px solid var(--border);
  padding:24px;border-radius:var(--radius);
  position:relative;overflow:hidden;
  transition:border-color 0.2s;
}
.stat-card:hover{border-color:rgba(255,255,255,0.15);}
.stat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--red);opacity:0;transition:opacity 0.2s;
}
.stat-card:hover::before{opacity:1;}
.stat-label{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--grey-1);margin-bottom:12px;}
.stat-value{font-family:var(--font-d);font-size:36px;font-weight:400;line-height:1;color:var(--white);}
.stat-sub{font-size:11px;color:var(--grey-2);margin-top:8px;}
.stat-icon{position:absolute;top:20px;right:20px;opacity:0.08;width:40px;height:40px;}

.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.section-title{font-family:var(--font-d);font-size:22px;font-weight:400;letter-spacing:0.01em;}
.section-title span{color:var(--red);font-style:italic;font-family:var(--font-d);font-size:20px;font-weight:400;}

/* ── TABLE ── */
.table-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.table-search{
  padding:16px 20px;border-bottom:1px solid var(--border);
  display:flex;gap:12px;align-items:center;
}
.search-input{
  flex:1;background:rgba(255,255,255,0.05);border:1px solid var(--border);
  color:var(--white);padding:8px 14px;border-radius:var(--radius);
  font-size:13px;font-weight:300;outline:none;
  transition:border-color 0.2s;
}
.search-input::placeholder{color:var(--grey-2);}
.search-input:focus{border-color:var(--red);}
.filter-select{
  background:rgba(255,255,255,0.05);border:1px solid var(--border);
  color:var(--white);padding:8px 14px;border-radius:var(--radius);
  font-size:12px;outline:none;cursor:pointer;
}
.filter-select option{background:var(--dark);}

table{width:100%;border-collapse:collapse;}
thead tr{border-bottom:1px solid var(--border);}
th{
  padding:12px 20px;text-align:left;
  font-size:10px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--grey-1);white-space:nowrap;
}
td{padding:14px 20px;font-size:13px;border-bottom:1px solid rgba(255,255,255,0.03);}
tbody tr{transition:background 0.15s;}
tbody tr:hover{background:rgba(255,255,255,0.03);}
tbody tr:last-child td{border-bottom:none;}

.badge{
  display:inline-flex;align-items:center;
  padding:3px 10px;border-radius:20px;
  font-size:10px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;
  white-space:nowrap;
}
.badge-green{background:var(--green-bg);color:#4caf7d;}
.badge-yellow{background:var(--yellow-bg);color:#e6a817;}
.badge-blue{background:var(--blue-bg);color:#5b9bd5;}
.badge-red{background:rgba(176,30,40,0.15);color:#e57373;}
.badge-grey{background:rgba(255,255,255,0.07);color:var(--grey-1);}

.action-btns{display:flex;gap:6px;align-items:center;}
.icon-btn{
  width:30px;height:30px;border-radius:var(--radius);
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.05);border:1px solid var(--border);
  color:var(--grey-1);transition:all 0.2s;
}
.icon-btn:hover{background:rgba(255,255,255,0.1);color:var(--white);}
.icon-btn.danger:hover{background:rgba(176,30,40,0.2);color:#e57373;border-color:rgba(176,30,40,0.3);}

/* ── MODAL ── */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.75);
  z-index:200;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
  animation:fadeIn 0.2s;
}
.modal-overlay.open{display:flex;}
.modal{
  background:var(--dark);border:1px solid var(--border);
  border-radius:var(--radius);width:100%;max-width:560px;max-height:90vh;
  overflow-y:auto;
  animation:slideUp 0.3s var(--ease);
}
@keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.modal-header{
  padding:24px 28px 20px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.modal-title{font-family:var(--font-d);font-size:20px;font-weight:400;}
.modal-title span{color:var(--red);font-style:italic;}
.modal-close{
  width:32px;height:32px;border-radius:var(--radius);
  background:rgba(255,255,255,0.06);border:1px solid var(--border);
  color:var(--grey-1);font-size:16px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;
}
.modal-close:hover{background:rgba(255,255,255,0.12);color:var(--white);}
.modal-body{padding:24px 28px;}
.modal-footer{
  padding:16px 28px 24px;
  display:flex;gap:10px;justify-content:flex-end;
  border-top:1px solid var(--border);
}

/* ── FORM ── */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-grid.full{grid-template-columns:1fr;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group.span2{grid-column:span 2;}
label{font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:var(--grey-1);}
.form-input,.form-select,.form-textarea{
  background:rgba(255,255,255,0.05);border:1px solid var(--border);
  color:var(--white);padding:10px 14px;border-radius:var(--radius);
  font-size:13px;font-weight:300;outline:none;
  transition:border-color 0.2s;width:100%;
}
.form-input::placeholder,.form-textarea::placeholder{color:var(--grey-2);}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--red);}
.form-select{cursor:pointer;appearance:none;}
.form-select option{background:var(--dark);}
.form-textarea{resize:vertical;min-height:80px;}
.form-divider{
  grid-column:span 2;
  border:none;border-top:1px solid var(--border);
  margin:4px 0;
}

/* ── CARDS KANBAN ── */
.kanban{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.kanban-col{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;}
.kanban-col-title{
  font-size:10px;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--grey-1);margin-bottom:14px;
  display:flex;align-items:center;justify-content:space-between;
}
.kanban-count{
  background:rgba(255,255,255,0.07);
  padding:2px 8px;border-radius:10px;font-size:10px;color:var(--grey-1);
}
.kanban-card{
  background:var(--dark);border:1px solid var(--border);
  border-radius:var(--radius);padding:14px;
  margin-bottom:10px;cursor:pointer;
  transition:border-color 0.2s,transform 0.2s;
  border-left:2px solid transparent;
}
.kanban-card:hover{border-color:rgba(255,255,255,0.15);transform:translateY(-1px);}
.kanban-card.red{border-left-color:var(--red);}
.kanban-card.green{border-left-color:#4caf7d;}
.kanban-card.yellow{border-left-color:#e6a817;}
.kanban-card.blue{border-left-color:#5b9bd5;}
.kanban-card-title{font-size:13px;font-weight:400;margin-bottom:6px;}
.kanban-card-client{font-size:11px;color:var(--grey-1);}
.kanban-card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:10px;}
.kanban-card-date{font-size:10px;color:var(--grey-2);}
.kanban-card-type{font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--red);}

/* ── SCADENZE ── */
.scadenze-list{display:flex;flex-direction:column;gap:10px;}
.scadenza-item{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:16px 20px;
  display:flex;align-items:center;gap:16px;
  transition:border-color 0.2s;
}
.scadenza-item:hover{border-color:rgba(255,255,255,0.15);}
.scadenza-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.scadenza-dot.urgente{background:var(--red);}
.scadenza-dot.prossima{background:#e6a817;}
.scadenza-dot.ok{background:#4caf7d;}
.scadenza-info{flex:1;}
.scadenza-titolo{font-size:13px;font-weight:400;margin-bottom:3px;}
.scadenza-sub{font-size:11px;color:var(--grey-1);}
.scadenza-data{font-size:12px;font-weight:500;color:var(--white);white-space:nowrap;}

/* ── EMPTY STATE ── */
.empty{
  text-align:center;padding:60px 20px;
  color:var(--grey-1);
}
.empty-icon{font-size:48px;margin-bottom:16px;opacity:0.3;}
.empty-title{font-family:var(--font-d);font-size:20px;color:var(--grey-1);margin-bottom:8px;}
.empty-sub{font-size:13px;color:var(--grey-2);}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:28px;right:28px;
  background:var(--card);border:1px solid var(--border);
  padding:14px 20px;border-radius:var(--radius);
  font-size:13px;color:var(--white);
  display:flex;align-items:center;gap:10px;
  transform:translateY(80px);opacity:0;
  transition:all 0.3s var(--ease);
  z-index:999;
  border-left:3px solid var(--red);
  min-width:260px;
}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success{border-left-color:#4caf7d;}

/* ── CONFIRM DIALOG ── */
.confirm-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.8);
  z-index:300;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.confirm-overlay.open{display:flex;}
.confirm-box{
  background:var(--dark);border:1px solid var(--border);
  border-radius:var(--radius);padding:32px;
  max-width:380px;width:90%;text-align:center;
  animation:slideUp 0.25s var(--ease);
}
.confirm-icon{font-size:36px;margin-bottom:16px;}
.confirm-title{font-family:var(--font-d);font-size:20px;margin-bottom:8px;}
.confirm-sub{font-size:13px;color:var(--grey-1);margin-bottom:24px;line-height:1.6;}
.confirm-btns{display:flex;gap:10px;justify-content:center;}

/* ── MOBILE TOGGLE ── */
.mobile-toggle{
  display:none;
  position:fixed;bottom:20px;right:20px;
  width:48px;height:48px;border-radius:50%;
  background:var(--red);color:var(--white);border:none;
  font-size:20px;z-index:150;
  box-shadow:0 4px 16px rgba(176,30,40,0.4);
  align-items:center;justify-content:center;
}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:90;}

/* ── PREVENTIVI ── */
.preventivo-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:20px 24px;
  display:grid;grid-template-columns:1fr auto;gap:16px;
  align-items:center;margin-bottom:12px;
  transition:border-color 0.2s;
}
.preventivo-card:hover{border-color:rgba(255,255,255,0.15);}
.preventivo-nome{font-size:14px;font-weight:400;margin-bottom:4px;}
.preventivo-meta{font-size:12px;color:var(--grey-1);}
.preventivo-importo{font-family:var(--font-d);font-size:22px;font-weight:400;text-align:right;margin-bottom:6px;}
.preventivo-importo span{font-size:13px;color:var(--grey-1);font-family:var(--font-b);}

/* ── RESPONSIVE ── */
@media(max-width:1100px){
  .stats-grid{grid-template-columns:1fr 1fr;}
  .kanban{grid-template-columns:1fr 1fr;}
}
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .sidebar-overlay.open{display:block;}
  .main{margin-left:0;}
  .mobile-toggle{display:flex;}
  .stats-grid{grid-template-columns:1fr 1fr;}
  .page{padding:20px 16px;}
  .topbar{padding:0 16px;}
  .kanban{grid-template-columns:1fr;}
  .form-grid{grid-template-columns:1fr;}
  .form-group.span2{grid-column:span 1;}
  .form-divider{grid-column:span 1;}
}
@media(max-width:480px){
  .stats-grid{grid-template-columns:1fr;}
}
</style>
</head>
