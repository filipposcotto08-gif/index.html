<script>

// ── CALENDARIO JS ──────────────────────────────────
let calState = { year: new Date().getFullYear(), month: new Date().getMonth(), selectedDate: null };
const MESI = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
const GIORNI_IT = ['Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato','Domenica'];

function getCalEvents(){ return DB.get('cal_events'); }
function saveCalEvents(list){ DB.set('cal_events', list); }

function initCalendario(){ renderCal(); }

function renderCal(){
  const {year, month, selectedDate} = calState;
  // Label mese
  const label = document.getElementById('cal-month-label');
  const mParts = MESI[month].split('');
  label.innerHTML = `${MESI[month].slice(0,-3)}<span>${MESI[month].slice(-3)}</span> ${year}`;

  const events = getCalEvents();
  const today = new Date(); today.setHours(0,0,0,0);

  // Prima cella: lunedì della settimana del 1° del mese
  const firstDay = new Date(year, month, 1);
  let startDow = firstDay.getDay(); // 0=dom
  startDow = startDow === 0 ? 6 : startDow - 1; // converti a lun=0

  const daysInMonth = new Date(year, month+1, 0).getDate();
  const daysInPrevMonth = new Date(year, month, 0).getDate();

  const grid = document.getElementById('cal-days-grid');
  grid.innerHTML = '';

  // Giorni mese precedente
  for(let i = startDow-1; i >= 0; i--){
    const d = daysInPrevMonth - i;
    const el = document.createElement('div');
    el.className = 'cal-day other-month';
    el.textContent = d;
    grid.appendChild(el);
  }

  // Giorni mese corrente
  for(let d = 1; d <= daysInMonth; d++){
    const el = document.createElement('div');
    el.className = 'cal-day';
    el.textContent = d;
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;

    const dt = new Date(year, month, d); dt.setHours(0,0,0,0);
    if(dt.getTime() === today.getTime()) el.classList.add('today');

    // Check eventi (cal + scadenze)
    const calEvs = events.filter(e => e.data === dateStr);
    const scadEvs = DB.get('scadenze').filter(s => s.data === dateStr);
    if(calEvs.length > 0 || scadEvs.length > 0){
      el.classList.add('has-events');
    }

    if(selectedDate === dateStr) el.classList.add('selected');

    el.onclick = () => selectCalDay(dateStr, d);
    grid.appendChild(el);
  }

  // Giorni mese successivo per completare griglia
  const totalCells = startDow + daysInMonth;
  const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
  for(let d = 1; d <= remaining; d++){
    const el = document.createElement('div');
    el.className = 'cal-day other-month';
    el.textContent = d;
    grid.appendChild(el);
  }

  // Aggiorna panel se c'è una data selezionata
  if(selectedDate) renderCalPanel(selectedDate);
}

function selectCalDay(dateStr, dayNum){
  calState.selectedDate = dateStr;
  renderCal();
  renderCalPanel(dateStr);
}

function renderCalPanel(dateStr){
  const [y,m,d] = dateStr.split('-').map(Number);
  const dt = new Date(y, m-1, d);
  const dow = dt.getDay();
  const dowIT = dow === 0 ? 6 : dow - 1;

  document.getElementById('cal-panel-date').innerHTML =
    `${GIORNI_IT[dowIT]} <span>${d}</span> ${MESI[m-1]} ${y}`;
  document.getElementById('cal-panel-sub').textContent = 'eventi del giorno';
  document.getElementById('cal-add-form').style.display = 'block';
  document.getElementById('cal-ev-titolo').value = '';

  const events = getCalEvents().filter(e => e.data === dateStr);
  const scadenze = DB.get('scadenze').filter(s => s.data === dateStr);
  const all = [
    ...events.map(e => ({...e, _src:'cal'})),
    ...scadenze.map(s => ({id:s.id, titolo:s.titolo, tipo:'Scadenza', _src:'scadenza', note:s.note}))
  ];

  const list = document.getElementById('cal-events-list');
  if(!all.length){
    list.innerHTML = '<div style="text-align:center;padding:20px;font-size:12px;color:var(--grey-2)">Nessun evento — aggiungine uno!</div>';
    return;
  }
  list.innerHTML = all.map(e => `
    <div class="cal-event-item">
      <div>
        <div class="cal-event-title">${e.titolo}</div>
        <div class="cal-event-type">${e.tipo||'Evento'}${e.note?` · ${e.note}`:''}</div>
      </div>
      ${e._src==='cal'?`<button class="icon-btn danger" style="flex-shrink:0" onclick="deleteCalEvent('${e.id}','${dateStr}')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
      </button>`:'<span style="font-size:9px;color:var(--grey-2);letter-spacing:0.1em">SCAD.</span>'}
    </div>`).join('');
}

function saveCalEvent(){
  const titolo = document.getElementById('cal-ev-titolo').value.trim();
  if(!titolo || !calState.selectedDate){ showToast('⚠️ Inserisci un titolo'); return; }
  const ev = {
    id: uid(),
    data: calState.selectedDate,
    titolo,
    tipo: document.getElementById('cal-ev-tipo').value,
  };
  const list = getCalEvents();
  list.push(ev);
  saveCalEvents(list);
  document.getElementById('cal-ev-titolo').value = '';
  renderCal();
  showToast('✓ Evento aggiunto', true);
}

function deleteCalEvent(id, dateStr){
  const list = getCalEvents().filter(e => e.id !== id);
  saveCalEvents(list);
  renderCal();
  showToast('🗑️ Evento eliminato');
}

function calPrev(){ calState.month--; if(calState.month<0){calState.month=11;calState.year--;} renderCal(); }
function calNext(){ calState.month++; if(calState.month>11){calState.month=0;calState.year++;} renderCal(); }
function calToday(){ calState.year=new Date().getFullYear(); calState.month=new Date().getMonth(); calState.selectedDate=null; renderCal(); }

// ── STORAGE ──────────────────────────────────────────
const DB = {
  get(k){ try{ return JSON.parse(localStorage.getItem('lda_'+k)||'[]'); }catch(e){return[];} },
  set(k,v){ localStorage.setItem('lda_'+k, JSON.stringify(v)); },
};


let editingId = { progetto:null, cliente:null, preventivo:null, scadenza:null };
let confirmCb = null;

// ── NAVIGATION ───────────────────────────────────────
const pageTitles = {
  dashboard:'Dashboard',progetti:'Progetti',clienti:'Clienti',
  preventivi:'Preventivi',scadenze:'Scadenze',calendario:'Calendario',kanban:'Stato Lavori',archivio:'Archivio'
};
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>{
    if(n.getAttribute('onclick')?.includes(name)) n.classList.add('active');
  });
  document.getElementById('topbarTitle').textContent = pageTitles[name];
  if(name==='dashboard') renderDashboard();
  if(name==='progetti') renderProgetti();
  if(name==='clienti') renderClienti();
  if(name==='preventivi') renderPreventivi();
  if(name==='scadenze') renderScadenze();
  if(name==='kanban') renderKanban();
  if(name==='archivio') renderArchivio();
  if(name==='statistiche') renderStatistiche();
  if(name==='calendario') renderCalendario();
  if(name==='calendario'){ initCalendario(); }
  if(window.innerWidth<768) closeSidebar();
}

// ── SIDEBAR MOBILE ───────────────────────────────────
function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('open');
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
}

// ── MODAL ────────────────────────────────────────────
function openModal(type, id=null){
  editingId[type]=id;
  const overlay = document.getElementById('modal-'+type);
  overlay.classList.add('open');
  const today = new Date().toISOString().split('T')[0];

  if(type==='progetto'){
    document.getElementById('modal-progetto-title').innerHTML = id ? 'Modifica <span>Progetto</span>' : 'Nuovo <span>Progetto</span>';
    if(id){
      const p = DB.get('progetti').find(x=>x.id===id);
      if(p){
        document.getElementById('p-nome').value=p.nome||'';
        document.getElementById('p-cliente').value=p.cliente||'';
        document.getElementById('p-tipo').value=p.tipo||'Residenziale';
        document.getElementById('p-stato').value=p.stato||'In Corso';
        document.getElementById('p-scadenza').value=p.scadenza||'';
        document.getElementById('p-importo').value=p.importo||'';
        document.getElementById('p-indirizzo').value=p.indirizzo||'';
        document.getElementById('p-note').value=p.note||'';
        // Mostra diario aggiornamenti
        document.getElementById('p-log-group').style.display='block';
        // Preview foto
        const preview = document.getElementById('p-foto-preview');
        if(p.foto){ preview.innerHTML=`<img src="${p.foto}" style="max-height:80px;border-radius:3px;object-fit:cover;">`; }
        else { preview.innerHTML=''; }
        const logList = document.getElementById('p-log-list');
        const logs = p.logs||[];
        logList.innerHTML = logs.length ? logs.map(l=>`
          <div style="padding:6px 0;border-bottom:1px solid var(--border);font-size:12px;color:var(--grey-1);">
            <span style="color:var(--red);margin-right:6px;">${l.data}</span>${l.testo}
          </div>`).join('') : '<div style="font-size:12px;color:var(--grey-2);padding:4px 0;">Nessun aggiornamento</div>';
        document.getElementById('p-foto').value=p.foto||'';
        if(p.foto){ document.getElementById('p-foto-preview').innerHTML=`<img src="${p.foto}" style="max-height:80px;border-radius:3px;">`; }
        else { document.getElementById('p-foto-preview').innerHTML='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg> Clicca per aggiungere una foto'; }
      }
    } else {
      ['p-nome','p-cliente','p-scadenza','p-importo','p-indirizzo','p-note'].forEach(id=>document.getElementById(id).value='');
      document.getElementById('p-log-group').style.display='none';
      document.getElementById('p-foto-preview').innerHTML='';
      document.getElementById('p-tipo').value='Residenziale';
      document.getElementById('p-stato').value='In Corso';
      document.getElementById('p-foto').value='';
      document.getElementById('p-foto-preview').innerHTML='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg> Clicca per aggiungere una foto del progetto';
    }
  }
  if(type==='cliente'){
    document.getElementById('modal-cliente-title').innerHTML = id ? 'Modifica <span>Cliente</span>' : 'Nuovo <span>Cliente</span>';
    if(id){
      const c=DB.get('clienti').find(x=>x.id===id);
      if(c){
        document.getElementById('c-nome').value=c.nome||'';
        document.getElementById('c-azienda').value=c.azienda||'';
        document.getElementById('c-tel').value=c.tel||'';
        document.getElementById('c-email').value=c.email||'';
        document.getElementById('c-citta').value=c.citta||'';
        document.getElementById('c-provenienza').value=c.provenienza||'Passaparola';
        document.getElementById('c-note').value=c.note||'';
      }
    } else {
      ['c-nome','c-azienda','c-tel','c-email','c-citta','c-note'].forEach(id=>document.getElementById(id).value='');
    }
  }
  if(type==='preventivo'){
    if(id){
      const pv=DB.get('preventivi').find(x=>x.id===id);
      if(pv){
        document.getElementById('pv-titolo').value=pv.titolo||'';
        document.getElementById('pv-cliente').value=pv.cliente||'';
        document.getElementById('pv-importo').value=pv.importo||'';
        document.getElementById('pv-data').value=pv.data||today;
        document.getElementById('pv-stato').value=pv.stato||'Bozza';
        document.getElementById('pv-note').value=pv.note||'';
      }
    } else {
      ['pv-titolo','pv-cliente','pv-importo','pv-note'].forEach(id=>document.getElementById(id).value='');
      document.getElementById('pv-data').value=today;
      document.getElementById('pv-stato').value='Bozza';
    }
  }
  if(type==='scadenza'){
    if(id){
      const s=DB.get('scadenze').find(x=>x.id===id);
      if(s){
        document.getElementById('s-titolo').value=s.titolo||'';
        document.getElementById('s-progetto').value=s.progetto||'';
        document.getElementById('s-data').value=s.data||'';
        document.getElementById('s-note').value=s.note||'';
      }
    } else {
      ['s-titolo','s-progetto','s-data','s-note'].forEach(id=>document.getElementById(id).value='');
    }
  }
}
function closeModal(type){
  document.getElementById('modal-'+type).classList.remove('open');
}

// ── SAVE ─────────────────────────────────────────────
function uid(){ return Date.now().toString(36)+Math.random().toString(36).substr(2,5); }

function saveProgetto(){
  const nome=document.getElementById('p-nome').value.trim();
  const cliente=document.getElementById('p-cliente').value.trim();
  if(!nome||!cliente){ showToast('⚠️ Nome e Cliente sono obbligatori'); return; }
  const data={
    id: editingId.progetto || uid(),
    nome, cliente,
    tipo: document.getElementById('p-tipo').value,
    stato: document.getElementById('p-stato').value,
    scadenza: document.getElementById('p-scadenza').value,
    importo: document.getElementById('p-importo').value,
    indirizzo: document.getElementById('p-indirizzo').value,
    note: document.getElementById('p-note').value,
    foto: document.getElementById('p-foto').value || '',
    creato: editingId.progetto ? undefined : new Date().toISOString(),
  };
  let list=DB.get('progetti');
  if(editingId.progetto){ list=list.map(x=>x.id===editingId.progetto?{...x,...data}:x); }
  else { list.unshift(data); }
  DB.set('progetti',list);
  closeModal('progetto');
  renderProgetti(); updateBadges(); renderDashboard();
  showToast('✓ Progetto salvato', true);
}

function saveCliente(){
  const nome=document.getElementById('c-nome').value.trim();
  if(!nome){ showToast('⚠️ Il nome è obbligatorio'); return; }
  const data={
    id: editingId.cliente || uid(),
    nome,
    azienda: document.getElementById('c-azienda').value,
    tel: document.getElementById('c-tel').value,
    email: document.getElementById('c-email').value,
    citta: document.getElementById('c-citta').value,
    provenienza: document.getElementById('c-provenienza').value,
    note: document.getElementById('c-note').value,
  };
  let list=DB.get('clienti');
  if(editingId.cliente){ list=list.map(x=>x.id===editingId.cliente?{...x,...data}:x); }
  else { list.unshift(data); }
  DB.set('clienti',list);
  closeModal('cliente');
  renderClienti(); updateBadges(); renderDashboard();
  showToast('✓ Cliente salvato', true);
}

function savePreventivo(){
  const titolo=document.getElementById('pv-titolo').value.trim();
  const cliente=document.getElementById('pv-cliente').value.trim();
  if(!titolo||!cliente){ showToast('⚠️ Titolo e Cliente sono obbligatori'); return; }
  const data={
    id: editingId.preventivo || uid(),
    titolo, cliente,
    importo: document.getElementById('pv-importo').value,
    data: document.getElementById('pv-data').value,
    stato: document.getElementById('pv-stato').value,
    note: document.getElementById('pv-note').value,
  };
  let list=DB.get('preventivi');
  if(editingId.preventivo){ list=list.map(x=>x.id===editingId.preventivo?{...x,...data}:x); }
  else { list.unshift(data); }
  DB.set('preventivi',list);
  closeModal('preventivo');
  renderPreventivi(); renderDashboard();
  showToast('✓ Preventivo salvato', true);
}

function saveScadenza(){
  const titolo=document.getElementById('s-titolo').value.trim();
  const data_val=document.getElementById('s-data').value;
  if(!titolo||!data_val){ showToast('⚠️ Titolo e Data sono obbligatori'); return; }
  const data={
    id: editingId.scadenza || uid(),
    titolo,
    progetto: document.getElementById('s-progetto').value,
    data: data_val,
    note: document.getElementById('s-note').value,
  };
  let list=DB.get('scadenze');
  if(editingId.scadenza){ list=list.map(x=>x.id===editingId.scadenza?{...x,...data}:x); }
  else { list.unshift(data); }
  DB.set('scadenze',list);
  closeModal('scadenza');
  renderScadenze(); renderDashboard();
  showToast('✓ Scadenza salvata', true);
}

// ── DELETE ───────────────────────────────────────────
function confirmDelete(type, id, nome){
  document.getElementById('confirm-sub').textContent = `Vuoi eliminare "${nome}"? Questa azione non può essere annullata.`;
  document.getElementById('confirm-overlay').classList.add('open');
  confirmCb = () => {
    let list = DB.get(type).filter(x=>x.id!==id);
    DB.set(type, list);
    document.getElementById('confirm-overlay').classList.remove('open');
    if(type==='progetti'){ renderProgetti(); updateBadges(); renderDashboard(); }
    if(type==='clienti'){ renderClienti(); updateBadges(); }
    if(type==='preventivi'){ renderPreventivi(); renderDashboard(); }
    if(type==='scadenze'){ renderScadenze(); renderDashboard(); }
