  const totale = preventivi.filter(p=>p.stato==='Accettato').reduce((s,p)=>s+Number(p.importo||0),0);
  w.document.write(`<!DOCTYPE html><html><head><title>Preventivi LDA</title>
  <style>body{font-family:Arial,sans-serif;padding:40px;color:#111;}h1{font-size:22px;margin-bottom:4px;}h2{font-size:13px;color:#888;font-weight:normal;margin-bottom:28px;}table{width:100%;border-collapse:collapse;}th{text-align:left;padding:10px;background:#f5f5f5;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;}.totale{text-align:right;padding:16px;font-weight:bold;font-size:15px;}</style>
  </head><body>
  <h1>Lineadiarchitettura — Preventivi</h1>
  <h2>Stampato il ${new Date().toLocaleDateString('it-IT')}</h2>
  <table><thead><tr><th>Titolo</th><th>Cliente</th><th>Data</th><th>Stato</th><th>Importo</th></tr></thead>
  <tbody>${rows}</tbody></table>
  <div class="totale">Totale Accettato: € ${totale.toLocaleString('it-IT')}</div>
  </body></html>`);
  w.document.close();
  setTimeout(()=>w.print(),400);
}

function renderStatistiche(){
  const progetti = DB.get('progetti').filter(p=>!p.archiviato);
  const preventivi = DB.get('preventivi');
  const clienti = DB.get('clienti');

  // Conteggi per tipo
  const tipi = {};
  progetti.forEach(p=>{ tipi[p.tipo||'Altro']=(tipi[p.tipo||'Altro']||0)+1; });
  // Conteggi per stato
  const stati = {};
  progetti.forEach(p=>{ stati[p.stato||'—']=(stati[p.stato||'—']||0)+1; });
  // Preventivi stats
  const pvAcc = preventivi.filter(p=>p.stato==='Accettato');
  const pvTot = preventivi.filter(p=>p.stato!=='Bozza');
  const tasso = pvTot.length ? Math.round(pvAcc.length/pvTot.length*100) : 0;
  const totAcc = pvAcc.reduce((s,p)=>s+Number(p.importo||0),0);
  // Provenienza clienti
  const prov = {};
  clienti.forEach(c=>{ prov[c.provenienza||'Altro']=(prov[c.provenienza||'Altro']||0)+1; });

  const barColor = (v, max) => {
    const pct = max ? Math.round(v/max*100) : 0;
    return `<div style="height:8px;background:var(--grey-3);border-radius:4px;margin-top:6px;">
      <div style="height:100%;width:${pct}%;background:var(--red);border-radius:4px;transition:width 0.6s;"></div>
    </div>`;
  };

  const maxTipo = Math.max(...Object.values(tipi),1);
  const maxProv = Math.max(...Object.values(prov),1);

  document.getElementById('stats-content').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:28px;">
      <div class="stat-card"><div class="stat-label">Valore Totale Accettato</div>
        <div class="stat-value" style="font-size:22px;">€ ${totAcc.toLocaleString('it-IT')}</div></div>
      <div class="stat-card"><div class="stat-label">Tasso Accettazione</div>
        <div class="stat-value">${tasso}%</div>
        <div class="stat-sub">${pvAcc.length} su ${pvTot.length} preventivi</div></div>
      <div class="stat-card"><div class="stat-label">Clienti Totali</div>
        <div class="stat-value">${clienti.length}</div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="table-wrap" style="padding:20px 24px;">
        <div style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--grey-1);margin-bottom:16px;">Progetti per Tipo</div>
        ${Object.entries(tipi).map(([k,v])=>`
          <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;font-size:13px;">
              <span>${k}</span><span style="color:var(--red);font-weight:500;">${v}</span>
            </div>${barColor(v,maxTipo)}
          </div>`).join('')||'<div style="color:var(--grey-2);font-size:13px;">Nessun dato</div>'}
      </div>
      <div class="table-wrap" style="padding:20px 24px;">
        <div style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--grey-1);margin-bottom:16px;">Provenienza Clienti</div>
        ${Object.entries(prov).map(([k,v])=>`
          <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;font-size:13px;">
              <span>${k}</span><span style="color:var(--red);font-weight:500;">${v}</span>
            </div>${barColor(v,maxProv)}
          </div>`).join('')||'<div style="color:var(--grey-2);font-size:13px;">Nessun dato</div>'}
      </div>
    </div>`;
}

function cambiaStatoProgetto(id, stato){
  let list = DB.get('progetti');
  list = list.map(p=>p.id===id?{...p,stato}:p);
  DB.set('progetti',list);
  renderProgetti(); renderDashboard(); renderKanban();
  showToast('✓ Stato aggiornato', true);
}
function cambiaStatoPreventivo(id, stato){
  let list = DB.get('preventivi');
  list = list.map(p=>p.id===id?{...p,stato}:p);
  DB.set('preventivi',list);
  renderPreventivi(); renderDashboard();
  showToast('✓ Stato aggiornato', true);
}

function showClienteDetail(id){
  const c = DB.get('clienti').find(x=>x.id===id);
  if(!c) return;
  document.getElementById('cd-title').innerHTML = c.nome + (c.azienda?` <span style="font-size:14px;color:var(--grey-1);font-style:normal">— ${c.azienda}</span>`:'');
  document.getElementById('cd-info').innerHTML = [
    c.tel?`<span>📞 <a href="tel:${c.tel}" style="color:var(--grey-1)">${c.tel}</a></span>`:'',
    c.email?`<span>✉️ <a href="mailto:${c.email}" style="color:var(--grey-1)">${c.email}</a></span>`:'',
    c.citta?`<span>📍 ${c.citta}</span>`:'',
    c.provenienza?`<span>🔗 ${c.provenienza}</span>`:'',
  ].filter(Boolean).join('');

  const preventivi = DB.get('preventivi').filter(p=>p.cliente.toLowerCase()===c.nome.toLowerCase());
  document.getElementById('cd-preventivi').innerHTML = preventivi.length
    ? preventivi.map(p=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;">
        <span>${p.titolo}</span>
        <span style="display:flex;gap:12px;align-items:center;">
          <span style="font-family:var(--font-d);color:var(--red);">${fmtEur(p.importo)}</span>
          <span class="badge ${statoBadge[p.stato]||'badge-grey'}">${p.stato}</span>
        </span>
      </div>`).join('')
    : '<div style="font-size:12px;color:var(--grey-2);padding:8px 0;">Nessun preventivo</div>';

  const progetti = DB.get('progetti').filter(p=>p.cliente.toLowerCase()===c.nome.toLowerCase());
  document.getElementById('cd-progetti').innerHTML = progetti.length
    ? progetti.map(p=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;">
        <span>${p.foto?`<img src="${p.foto}" style="width:28px;height:28px;object-fit:cover;border-radius:2px;vertical-align:middle;margin-right:8px;">`:''}${p.nome}</span>
        <span class="badge ${statoBadge[p.stato]||'badge-grey'}">${p.stato}</span>
      </div>`).join('')
    : '<div style="font-size:12px;color:var(--grey-2);padding:8px 0;">Nessun progetto</div>';

  document.getElementById('modal-cliente-detail').classList.add('open');
}
function updateBadges(){
  document.getElementById('badge-progetti').textContent=DB.get('progetti').length;
  document.getElementById('badge-clienti').textContent=DB.get('clienti').length;
}

// ── FILTER ───────────────────────────────────────────
let _filters={progetti:{text:'',status:'',type:''}};
function filterTable(type, val){
  if(type==='progetti'){ _filters.progetti.text=val; renderProgetti(_filters.progetti.text,_filters.progetti.status,_filters.progetti.type); }
  if(type==='clienti') renderClienti();
}
function filterByStatus(type, val){
  if(type==='progetti'){ _filters.progetti.status=val; renderProgetti(_filters.progetti.text,_filters.progetti.status,_filters.progetti.type); }
}
function filterByType(type, val){
  if(type==='progetti'){ _filters.progetti.type=val; renderProgetti(_filters.progetti.text,_filters.progetti.status,_filters.progetti.type); }
}

// ── TOAST ────────────────────────────────────────────
function showToast(msg, success=false){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className='toast'+(success?' success':'');
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

// ── CLOSE MODAL ON OVERLAY CLICK ─────────────────────
document.querySelectorAll('.modal-overlay').forEach(o=>{
  o.addEventListener('click',e=>{ if(e.target===o) o.classList.remove('open'); });
});

// ── INIT ─────────────────────────────────────────────
document.getElementById('topbarDate').textContent = new Date().toLocaleDateString('it-IT',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
updateBadges();
renderDashboard();
</script>
</body>
