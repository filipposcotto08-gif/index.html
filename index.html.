function addLogEntry(){
  const input = document.getElementById('p-log-new');
  const testo = input.value.trim();
  if(!testo) return;
  const id = editingId.progetto;
  if(!id) return;
  let list = DB.get('progetti');
  const p = list.find(x=>x.id===id);
  if(!p) return;
  if(!p.logs) p.logs=[];
  const oggi = new Date().toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit',year:'numeric'});
  p.logs.unshift({data:oggi, testo});
  DB.set('progetti',list);
  input.value='';
  // Aggiorna lista
  const logList = document.getElementById('p-log-list');
  logList.innerHTML = p.logs.map(l=>`
    <div style="padding:6px 0;border-bottom:1px solid var(--border);font-size:12px;color:var(--grey-1);">
      <span style="color:var(--red);margin-right:6px;">${l.data}</span>${l.testo}
    </div>`).join('');
  showToast('✓ Aggiornamento aggiunto', true);
}

