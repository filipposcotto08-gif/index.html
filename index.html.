function renderDashboard(){
  const progetti=DB.get('progetti');
  const clienti=DB.get('clienti');
  const preventivi=DB.get('preventivi');
  const scadenze=DB.get('scadenze');
  const today=new Date(); today.setHours(0,0,0,0);
  const in30=new Date(today); in30.setDate(in30.getDate()+30);

  const attivi=progetti.filter(p=>!p.archiviato&&(p.stato==='In Corso'||p.stato==='Cantiere')).length;
  document.getElementById('stat-attivi').textContent=attivi;
  document.getElementById('stat-clienti').textContent=clienti.length;
  const valAcc=preventivi.filter(p=>p.stato==='Accettato').reduce((s,p)=>s+Number(p.importo||0),0);
  document.getElementById('stat-valore').textContent='€ '+valAcc.toLocaleString('it-IT');
  const sc=scadenze.filter(s=>{ const d=new Date(s.data); d.setHours(0,0,0,0); return d>=today&&d<=in30; }).length;
  document.getElementById('stat-scadenze').textContent=sc;

  // Ultimi 5 progetti
  const recenti=progetti.slice(0,5);
  const tb=document.getElementById('dash-progetti-tbody');
  tb.innerHTML=recenti.length?recenti.map(p=>`<tr>
    <td style="font-size:13px">${p.nome}</td>
    <td style="font-size:12px;color:var(--grey-1)">${p.cliente}</td>
    <td><span class="badge ${statoBadge[p.stato]||'badge-grey'}" style="font-size:9px">${p.stato}</span></td>
  </tr>`).join(''):`<tr><td colspan="3"><div class="empty" style="padding:24px"><div class="empty-sub">Nessun progetto</div></div></td></tr>`;

  // Prossime scadenze dashboard
  const prossime=scadenze.filter(s=>{ const d=new Date(s.data); d.setHours(0,0,0,0); return d>=today; })
    .sort((a,b)=>new Date(a.data)-new Date(b.data)).slice(0,4);
  const sl=document.getElementById('dash-scadenze-list');
  sl.innerHTML=prossime.length?prossime.map(s=>{
    const d=new Date(s.data); d.setHours(0,0,0,0);
    const diff=Math.round((d-today)/(1000*60*60*24));
    const urg=diff<=7?'urgente':diff<=30?'prossima':'ok';
    return `<div class="scadenza-item" style="margin-bottom:8px">
      <div class="scadenza-dot ${urg}"></div>
      <div class="scadenza-info"><div class="scadenza-titolo" style="font-size:13px">${s.titolo}</div>
      <div class="scadenza-sub">${s.progetto||''}</div></div>
      <div class="scadenza-data">${fmtDate(s.data)}</div>
    </div>`;
  }).join(''):`<div class="empty" style="padding:24px"><div class="empty-sub">Nessuna scadenza imminente</div></div>`;
}

